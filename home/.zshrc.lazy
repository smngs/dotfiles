# ----------------- env --------------------
if type nvim > /dev/null 2>&1; then
  export EDITOR='nvim'
fi

case ${OSTYPE} in
    darwin*)
        # path_helper を先に実行してから追加
        eval "$(/usr/libexec/path_helper)"
        export PATH="/opt/homebrew/bin:/usr/local/Homebrew/bin:$HOME/.local/bin:$PATH"
        
        # pyenv を遅延読み込み
        if command -v pyenv >/dev/null 2>&1; then
            eval "$(pyenv init --path)"
        fi

        (( ${+commands[gdate]} )) && alias date='gdate'
        (( ${+commands[gls]} )) && alias ls='gls'
        (( ${+commands[gmkdir]} )) && alias mkdir='gmkdir'
        (( ${+commands[gcp]} )) && alias cp='gcp'
        (( ${+commands[gmv]} )) && alias mv='gmv'
        (( ${+commands[grm]} )) && alias rm='grm'
        (( ${+commands[gdu]} )) && alias du='gdu'
        (( ${+commands[ghead]} )) && alias head='ghead'
        (( ${+commands[gtail]} )) && alias tail='gtail'
        (( ${+commands[gsed]} )) && alias sed='gsed'
        (( ${+commands[ggrep]} )) && alias grep='ggrep'
        (( ${+commands[gfind]} )) && alias find='gfind'
        (( ${+commands[gdirname]} )) && alias dirname='gdirname'
        (( ${+commands[gxargs]} )) && alias xargs='gxargs'
        ;;
    linux*)
        ;;
esac

[[ -f $HOME/.secrets ]] && zsh-defer source $HOME/.secrets

# ----------------- alias --------------------

if [[ $(command -v eza) ]]; then
  alias l='eza --icons'
  alias ls='eza --icons'
  alias la='eza --icons -a'
  alias ll='eza --icons -lh'
  alias lla='eza --icons -lah'
fi

if [[ $(command -v bat) ]]; then
  alias cat='bat'
fi

if [[ $(command -v hexyl) ]]; then
  alias od='hexyl'
fi

if [[ $(command -v procs) ]]; then
  alias ps='procs'
fi

if [[ $(command -v ranger) ]]; then
  alias ranger='TERM=xterm-256color ranger'
fi

alias tree='tree -C'
alias rm='rm -i'
alias mv='mv -i'
alias df='df -h'
alias q='exit'
alias c='clear'
alias f='yazi'

alias claude='claude --enable-auto-mode'
alias auto-commit='claude -p "/commit"'
alias auto-pr='claude -p "/pr"'
alias auto-ship='claude -p "/commit-pr"'

alias ..='\cd ..'
alias ..2='\cd ../..'
alias ..3='\cd ../../..'
alias ..4='\cd ../../../..'
alias ..5='\cd ../../../../..'

# ----------------- function -----------------

# do_enter (pwd, ls, git status)
function do_enter() {
    if [ -n "$BUFFER" ]; then
        zle accept-line
        return 0
    fi
    echo
    echo -e "\e[0;33m--- pwd ---\e[0m"
    pwd
    echo
    echo -e "\e[0;33m--- ls ---\e[0m"
      ls
    if [ "$(git rev-parse --is-inside-work-tree 2> /dev/null)" = 'true' ]; then
        echo
        echo -e "\e[0;33m--- git status ---\e[0m"
        git status -sb
    fi
    echo
    echo
    zle reset-prompt
    return 0
}

zle -N do_enter
bindkey '^m' do_enter

# ----------------- Rust -----------------
export RUSTC_WRAPPER=/usr/bin/sccache

# ----------------- zatta-zone (TBR) -----------------
# fzf-tmux
# export FZF_TMUX=1
# export FZF_TMUX_OPTS="-p 80%"
# export ENHANCD_FILTER='fzf-tmux -p'

# zeno
export ZENO_HOME="$HOME/.config/zeno"
export ZENO_ENABLE_SOCK=1
export ZENO_DISABLE_EXECUTE_CACHE_COMMAND=1
#
# export ZENO_ENABLE_FZF_TMUX=1
# export ZENO_FZF_TMUX_OPTIONS="-p 50%"

export FZF_DEFAULT_OPTS="--height 30% --layout=reverse --border --ansi --margin 1,3"
export ZENO_DISABLE_BUILTIN_COMPLETION=1
export ZENO_GIT_CAT="bat --color=always"
export ZENO_GIT_TREE="eza --tree"


# ----------------- plugins -----------------
## -> .zinitrc

source ~/.zinitrc

# ----------------- autoloads -----------------

autoload -Uz cdr
autoload -Uz chpwd_recent_dirs
autoload -Uz add-zsh-hook

add-zsh-hook chpwd chpwd_recent_dirs

# 補完システムの初期化（遅延読み込み）
# 24時間以内なら補完ダンプのチェックをスキップして高速化
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  zsh-defer compinit
else
  zsh-defer compinit -C
fi
